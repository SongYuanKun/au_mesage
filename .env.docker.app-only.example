# =============================================================================
# 方案 B：仅起应用容器（docker-compose.yml），MySQL 为已有实例（本机 / RDS / 局域网）
# 用法：复制需要的键到根目录 .env，或：cp .env.docker.app-only.example .env 后改值
# 启动：docker compose -f docker-compose.yml up --build -d
# =============================================================================
#
# —— 库在「本机宿主机」、监听 3306（与 docker 同机）——
#    容器内 127.0.0.1 不是宿主机，必须：
MYSQL_HOST=host.docker.internal
#
# —— 库在云 RDS / 另一台机器 ——
#    填可解析主机名或 IP，不要用 127.0.0.1（除非 MySQL 真的跑在容器里）
# MYSQL_HOST=your-db.xxxxx.rds.aliyuncs.com
#
# 与线上一致即可（示例库名仅作说明，请改成你的库名，如 gold_price）
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=gold_price

API_HOST=0.0.0.0
API_PORT=8083

# 与本地开发一致即可；Playwright 在容器内需额外资源，按需开启
WEBSITE_URL=https://example.com/
ENABLE_PLAYWRIGHT=false

# MySQL 侧请确认：
# 1) 已对「应用使用的用户」授权可从 Docker 网段连接（常见为 'user'@'%' 或指定网段），
#    不能仅限 'user'@'localhost'，否则容器连上会拒绝。
# 2) 目标库已执行 scripts/init.sql（表 price_data / exchange_rate / daily_ohlc）。
