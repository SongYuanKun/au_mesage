# 与 docker-compose.mysql.yml 配套：内置 MySQL 容器 + 应用
# 使用：cp .env.mysql.example .env.mysql 后编辑密码，再执行
#   docker compose --env-file .env.mysql -f docker-compose.mysql.yml up --build -d
#
# 注意：应用容器内 MYSQL_HOST 由 compose 固定为服务名 mysql，勿改此处 MYSQL_HOST 期望生效——
# 连接地址以 compose 中的 environment.MYSQL_HOST=mysql 为准。

MYSQL_HOST=mysql
MYSQL_USER=root
MYSQL_PASSWORD=change_me_strong_password
MYSQL_DATABASE=price_data

API_HOST=0.0.0.0
API_PORT=8083

WEBSITE_URL=https://your_website_url.com
ENABLE_PLAYWRIGHT=false
GOLD_API_INTERVAL=60

WECHAT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
