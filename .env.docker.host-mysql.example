# 复制为 .env 片段或合并进 .env：Docker 只跑应用、MySQL 在「宿主机本机」时使用。
# 容器内不能用 127.0.0.1 指宿主机，需使用 host.docker.internal（docker-compose.yml 已含 extra_hosts）。
#
# MYSQL_HOST=host.docker.internal
# MYSQL_USER=你的用户
# MYSQL_PASSWORD=你的密码
# MYSQL_DATABASE=gold_price
#
# MySQL 须允许远程登录该用户（例如对 % 或 docker 网段授权），且已执行 scripts/init.sql。
