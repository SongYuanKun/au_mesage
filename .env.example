# MySQL 配置（必填）
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=price_data

# API 配置
API_HOST=0.0.0.0
API_PORT=8083

# 采集目标网站（Playwright 采集器使用，ENABLE_PLAYWRIGHT=true 时必填）
WEBSITE_URL=https://your_website_url.com

# 数据采集器控制
ENABLE_PLAYWRIGHT=false       # 是否启用 Playwright 采集器（默认关闭，使用 API 采集）
GOLD_API_INTERVAL=60          # 国际金价采集间隔（秒，默认60）

# 价格提醒推送渠道（可选，配置后自动启用）
# 企业微信机器人
WECHAT_WEBHOOK_URL=
# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 邮件推送
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# 使用方法：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 编辑 .env 填入实际的配置值
# 3. .env 文件已在 .gitignore 中忽略，不会被提交到 Git
