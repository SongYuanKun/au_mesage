# MySQL 配置（必填）
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=price_data

# API 配置
API_HOST=0.0.0.0
API_PORT=8083

# 采集目标网站（必填）
WEBSITE_URL=https://your_website_url.com

# 使用方法：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 编辑 .env 填入实际的配置值
# 3. .env 文件已在 .gitignore 中忽略，不会被提交到 Git
